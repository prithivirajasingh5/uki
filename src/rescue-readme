  WIFI (iwd — no wpa_supplicant needed)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  iwctl
    device list
    station wlan0 scan
    station wlan0 get-networks
    station wlan0 connect "SSID"
    quit

  Verify:   ip addr show wlan0
  DNS:      /etc/resolv.conf already points at 8.8.8.8 / 1.1.1.1

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  DISK TOOLS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  lsblk -f                  show disks + filesystems
  fdisk -l                  list partitions
  parted /dev/nvme0n1       interactive partitioning (GPT)
  gdisk /dev/nvme0n1        GPT-specific partitioning

  Filesystems:
    mkfs.ext4 /dev/sdX1
    mkfs.btrfs /dev/sdX1
    mkfs.fat -F32 /dev/sdX1     (EFI partition)
    fsck.ext4 /dev/sdX1

  Mount:
    mkdir /mnt/disk
    mount /dev/nvme0n1p2 /mnt/disk
    mount /dev/nvme0n1p1 /mnt/disk/boot/efi

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  LVM + LUKS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  LVM:
    vgscan && vgchange -ay      activate all volume groups
    lvs                         list logical volumes

  LUKS:
    cryptsetup open /dev/sdX1 cryptroot
    mount /dev/mapper/cryptroot /mnt/disk

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  DATA RECOVERY
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Drive health:
    smartctl -a /dev/nvme0n1
    nvme smart-log /dev/nvme0n1

  Image a failing drive (skips bad sectors):
    ddrescue /dev/sdX /mnt/disk/rescue.img /mnt/disk/rescue.log

  Recover lost partitions:
    testdisk /dev/sdX

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  CHROOT INTO INSTALLED SYSTEM
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  mount /dev/nvme0n1p2 /mnt/disk
  mount /dev/nvme0n1p1 /mnt/disk/boot/efi
  mount --bind /dev  /mnt/disk/dev
  mount --bind /proc /mnt/disk/proc
  mount --bind /sys  /mnt/disk/sys
  chroot /mnt/disk

  Inside chroot: grub-install, update-grub, passwd, apt, etc.

